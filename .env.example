# Never put real keys here. Copy to `.env` and fill values.

# GitHub (Engineer + QA)
GITHUB_TOKEN='ghp_...'
GITHUB_REPO='manal-aamir/launchmind-SIXSEVEN'

# Slack (CEO summaries + reminders + launches)
SLACK_BOT_TOKEN='xoxb-...'
SLACK_CHANNEL_ID='C...'
LAUNCHES_CHANNEL_ID='C...'

# SendGrid (invoice + marketing + day 14 email)
SENDGRID_API_KEY='SG...'
SENDGRID_FROM_EMAIL='verified@yourdomain.com'
SENDGRID_TO_EMAIL='test@yourdomain.com'

# Groq (primary LLM)
GROQ_API_KEY='gsk_...'
GROQ_MODEL='llama-3.3-70b-versatile'

# DeepSeek (optional fallback)
DEEPSEEK_API_KEY='sk_...'
DEEPSEEK_MODEL='deepseek-chat'

# Gemini (optional fallback)
GEMINI_API_KEY='AIza...'
GEMINI_MODEL='gemini-2.0-flash'

# Redis (bonus pub/sub)
REDIS_HOST='localhost'
REDIS_PORT='6379'

